<section id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="contact-left">
        <p class="section-label" data-i18n="contact.label">// Hagamos algo juntos</p>
        <h2 data-i18n="contact.title">¿Trabajamos juntos?</h2>
        <p data-i18n="contact.description">
          Abierto a nuevas oportunidades, proyectos freelance o simplemente charlar sobre
          DevOps y Infraestructura Cloud. No dudes en escribirme.
        </p>

        <div class="contact-links">
          <a href="https://www.linkedin.com/in/juliocesarruizcardenas/" target="_blank" rel="noopener" class="contact-link card">
            <div class="cl-icon">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="var(--accent)">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <strong>LinkedIn</strong>
              <span>juliocesarruizcardenas</span>
            </div>
          </a>

          <a href="https://github.com/JulioRuizdev" target="_blank" rel="noopener" class="contact-link card">
            <div class="cl-icon">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="var(--accent)">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div>
              <strong>GitHub</strong>
              <span>JulioRuizdev</span>
            </div>
          </a>
        </div>
      </div>

      <div class="availability card">
        <div class="avail-indicator">
          <div class="pulse"></div>
          <span class="avail-text" data-i18n="contact.availability.status">DISPONIBLE</span>
        </div>
        <h3 data-i18n="contact.availability.title">Listo para el próximo desafío</h3>
        <p data-i18n="contact.availability.description">
          Busco oportunidades donde pueda aplicar mis skills en Cloud y DevOps para construir
          infraestructura robusta y pipelines eficientes.
        </p>
        <a href="https://www.linkedin.com/in/juliocesarruizcardenas/" target="_blank" rel="noopener" class="btn-primary" style="width:100%;justify-content:center;" data-i18n="contact.availability.cta">
          Conectar en LinkedIn →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .contact-left h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }
  .contact-left > p {
    color: var(--text-subtle);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .contact-links { display: flex; flex-direction: column; gap: 1rem; }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.2rem 1.4rem;
    text-decoration: none;
    color: var(--text);
    border-radius: 12px;
    transition: all 0.2s;
  }
  .contact-link:hover { transform: translateX(4px); }

  .cl-icon {
    width: 38px; height: 38px;
    border-radius: 8px;
    background: var(--accent-glow);
    border: 1px solid var(--tag-border);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .contact-link strong { display: block; font-size: 0.9rem; font-weight: 700; }
  .contact-link span {
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .availability { padding: 2.5rem; border-radius: 16px; }

  .avail-indicator {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .avail-text {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    color: #34d399;
    letter-spacing: 0.08em;
  }

  .availability h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 0.7rem; }
  .availability p  { color: var(--text-subtle); font-size: 0.9rem; line-height: 1.7; margin-bottom: 1.5rem; }

  @media (max-width: 768px) {
    .contact-inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>

<script>
  import { getTranslations } from '../i18n/translations.js';

  function updateContactTexts() {
    const currentLang = document.documentElement.lang || 'es';
    const t = getTranslations(currentLang);
    
    // Update all text elements with translations
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      const keys = key.split('.');
      let value = t;
      
      for (const k of keys) {
        value = value[k];
        if (!value) break;
      }
      
      if (value) {
        el.textContent = value;
      }
    });
  }

  // Initial load
  updateContactTexts();

  // Listen for language changes
  window.addEventListener('languageChanged', updateContactTexts);
</script>
