---
const categories = [
  {
    icon: '☁️',
    nameKey: 'skills.categories.cloud',
    name: 'Cloud',
    tags: ['AWS EC2', 'AWS S3', 'AWS Lambda', 'AWS EKS', 'Azure VM', 'Azure AKS', 'Azure DevOps'],
  },
  {
    icon: '🐳',
    nameKey: 'skills.categories.containers',
    name: 'Contenedores & Orquestación',
    tags: ['Docker', 'Kubernetes', 'Helm', 'Docker Compose', 'containerd'],
  },  {
    icon: '⚙️',
    nameKey: 'skills.categories.iac',
    name: 'IaC & Automatización',
    tags: ['Terraform', 'Ansible', 'Bash', 'Python'],
  },
  {
    icon: '🔁',
    nameKey: 'skills.categories.cicd',
    name: 'CI/CD',
    tags: ['GitHub Actions', 'Jenkins', 'GitLab CI'],
  },
  {
    icon: '📊',
    nameKey: 'skills.categories.monitoring',
    name: 'Monitoring & Observabilidad',
    tags: ['Prometheus', 'Grafana', 'Zabbix', 'CloudWatch'],
  },
  {
    icon: '🔐',
    nameKey: 'skills.categories.security',
    name: 'Seguridad & Redes',
    tags: ['VPC', 'IAM', 'Vault', 'SSL/TLS', 'NGINX'],
  },
];
---

<section id="skills">
  <div class="container">
    <p class="section-label" data-i18n="skills.label">// Stack tecnológico</p>
    <h2 class="section-title" data-i18n="skills.title">Herramientas</h2>
    <p class="section-sub" data-i18n="skills.subtitle">El stack que uso para construir y escalar infraestructura cloud.</p>

    <div class="skills-grid">
      {categories.map(cat => (
        <div class="skill-card card">
          <div class="skill-header">
            <div class="skill-icon">{cat.icon}</div>
            <span class="skill-name" data-i18n={cat.nameKey}>{cat.name}</span>
          </div>
          <div class="skill-tags">
            {cat.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.2rem;
  }

  .skill-card {
    padding: 1.8rem;
  }
  .skill-card:hover { transform: translateY(-2px); }

  .skill-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
  }

  .skill-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: var(--accent-glow);
    border: 1px solid var(--tag-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .skill-name {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>

<script>
  import { getTranslations } from '../i18n/translations.js';

  function updateSkillsTexts() {
    const currentLang = document.documentElement.lang || 'es';
    const t = getTranslations(currentLang);
    
    // Update all text elements with translations
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      const keys = key.split('.');
      let value = t;
      
      for (const k of keys) {
        value = value[k];
        if (!value) break;
      }
      
      if (value) {
        el.textContent = value;
      }
    });
  }

  // Initial load
  updateSkillsTexts();

  // Listen for language changes
  window.addEventListener('languageChanged', updateSkillsTexts);
</script>
