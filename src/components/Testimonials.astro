---
const testimonials = [
  {
    initials: 'JK',
    nameKey: 'testimonials.list.0.name',
    name: 'Junior Klinsman Diaz Vallejos',
    roleKey: 'testimonials.list.0.role',
    role: 'SysOps & Cloud Administrator · Azure · Security Hardening',
    dateKey: 'testimonials.list.0.date',
    date: '7 de marzo de 2026',
    textKey: 'testimonials.list.0.text',
    text: 'Tuve la oportunidad de trabajar con Julio durante su etapa en el equipo y fue una muy buena experiencia. Desde el inicio me sorprendieron sus habilidades técnicas para el puesto, así como su capacidad para entender rápidamente los problemas y buscar soluciones. Además, algo que siempre destacó en él fue su apertura para escuchar, recibir feedback y seguir aprendiendo. Tiene una actitud muy positiva frente a los retos y siempre mostraba interés por entender las cosas a fondo.',
    linkedinUrl: 'https://www.linkedin.com/in/julio-cesar-ruiz-cardenas/',
  },
];
---

<section id="testimonials">
  <div class="container">
    <p class="section-label" data-i18n="testimonials.label">// Recomendaciones</p>
    <h2 class="section-title" data-i18n="testimonials.title">Lo que dicen colegas</h2>
    <p class="section-sub" data-i18n="testimonials.subtitle">Recomendaciones verificadas de profesionales con quienes he trabajado.</p>

    <div class="testimonials-list">
      {testimonials.map(t => (
        <div class="testimonial-card card">
          <div class="quote-mark">"</div>
          <div class="t-date-row">
            <span class="t-date" data-i18n={t.dateKey}>{t.date}</span>
            <span class="t-via">· LinkedIn</span>
          </div>
          <p class="t-text" data-i18n={t.textKey}>{t.text}</p>
          <div class="t-footer">
            <div class="t-author">
              <div class="t-avatar">{t.initials}</div>
              <div class="t-info">
                <strong class="t-name" data-i18n={t.nameKey}>{t.name}</strong>
                <span class="t-role" data-i18n={t.roleKey}>{t.role}</span>
              </div>
            </div>
            <a
              href={t.linkedinUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="t-badge"
              data-i18n="testimonials.verifyLabel"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="11" height="11" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              Ver en LinkedIn
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .testimonial-card {
    padding: 2rem 2.2rem;
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .testimonial-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .testimonial-card:hover { transform: translateX(4px); }
  .testimonial-card:hover::before { opacity: 1; }

  .quote-mark {
    font-family: 'DM Mono', monospace;
    font-size: 4rem;
    line-height: 1;
    color: var(--accent);
    opacity: 0.12;
    position: absolute;
    top: 12px;
    right: 24px;
    user-select: none;
    pointer-events: none;
  }

  .t-date-row {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 1rem;
  }

  .t-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--accent);
    background: var(--tag-bg);
    border: 1px solid var(--tag-border);
    border-radius: 5px;
    padding: 0.15rem 0.55rem;
  }

  .t-via {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-muted);
  }

  .t-text {
    color: var(--text-subtle);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1.6rem;
    max-width: 72ch;
  }

  .t-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .t-author {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .t-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), #34d399);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
  }

  .t-info { display: flex; flex-direction: column; gap: 2px; }

  .t-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text);
  }

  .t-role {
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--text-muted);
  }

  .t-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'DM Mono', monospace;
    font-size: 0.68rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--tag-border);
    border-radius: 6px;
    padding: 0.35rem 0.75rem;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .t-badge:hover {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  @media (max-width: 600px) {
    .t-footer { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  import { getTranslations } from '../i18n/translations.js';

  function updateTestimonialsTexts() {
    const currentLang = document.documentElement.lang || 'es';
    const t = getTranslations(currentLang);

    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      const keys = key.split('.');
      let value = t;
      for (const k of keys) {
        value = value?.[k];
        if (!value) break;
      }
      if (value && typeof value === 'string') {
        el.textContent = value;
      }
    });
  }

  updateTestimonialsTexts();
  window.addEventListener('languageChanged', updateTestimonialsTexts);
</script>